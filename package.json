{
  "name": "mariseth_farms",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start --reset-cache",
    "android": "expo run:android",
    "android:release": "cd android && ./gradlew clean && cd .. && expo run:android --variant release",
    "android:clean": "cd android && ./gradlew clean && cd ..",
    "ios": "expo run:ios",
    "ios:release": "expo run:ios --configuration Release",
    "reset": "watchman watch-del-all && rm -rf node_modules/ && npm cache clean --force && npm install && npm start",
    "web": "expo start --web",
    "lint": "expo lint"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/elements": "^2.3.8",
    "@react-navigation/native": "^7.1.6",
    "@shopify/flash-list": "1.7.6",
    "@tanstack/react-query": "^5.80.6",
    "apisauce": "^3.1.1",
    "date-fns": "^4.1.0",
    "expo": "53.0.11",
    "expo-blur": "~14.1.4",
    "expo-build-properties": "~0.14.6",
    "expo-font": "~13.3.1",
    "expo-haptics": "~14.1.4",
    "expo-image": "~2.3.0",
    "expo-linear-gradient": "~14.1.4",
    "expo-linking": "^7.1.5",
    "expo-router": "~5.1.0",
    "expo-splash-screen": "~0.30.8",
    "expo-status-bar": "~2.2.3",
    "formik": "^2.4.6",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.3",
    "react-native-actions-sheet": "^0.9.7",
    "react-native-confirmation-code-field": "^7.6.1",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-mmkv": "^3.2.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "15.11.2",
    "react-native-toast-notifications": "^3.4.0",
    "react-native-ui-datepicker": "^3.1.2",
    "yup": "^1.6.1",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.0.10",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~9.2.0",
    "typescript": "~5.8.3"
  },
  "private": true
}
