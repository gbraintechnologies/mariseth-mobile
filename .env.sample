# Copy to .env (or use yarn env:dev / yarn env:prod)
# Mobile app uses EXPO_PUBLIC_* — not NEXT_PUBLIC_* from the web app.

EXPO_PUBLIC_API_URL=https://marsapi.omnicoreerp.com/api/v1
EXPO_PUBLIC_WEB_SOCKET_URL=wss://marsapi.omnicoreerp.com/ws/engine
EXPO_PUBLIC_GOOGLE_AI_API_KEY=
EXPO_PUBLIC_ENVIRONMENT=production
EXPO_PUBLIC_APP_ENV=production
EXPO_PUBLIC_LOCAL_DB_KEY=mariseth-local-db-key-prod
EXPO_PUBLIC_WEATHER_API_KEY=
